{
  "name": "debugpress",
  "version": "4.2.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "npm run lint:js && npm run lint:css",
    "lint:js": "eslint \"js/**/*.js\"",
    "lint:css": "stylelint \"scss/**/*.scss\"",
    "lint:css:fix": "stylelint \"scss/**/*.scss\" --fix"
  },
  "devDependencies": {
    "@wordpress/eslint-plugin": "^24.5.0",
    "@wordpress/stylelint-config": "^23.35.0",
    "eslint": "^10.1.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0"
  },
  "overrides": {
    "@wordpress/stylelint-config": {
      "stylelint": "$stylelint"
    }
  }
}
